{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://zitouni-ecole.onrender.com/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://zitouni-ecole.onrender.com/socket.io/$1" },
    { "source": "/uploads/(.*)", "destination": "https://zitouni-ecole.onrender.com/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
